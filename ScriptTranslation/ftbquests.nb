Cell[BoxData[
 RowBox[{
  RowBox[{"dictQ", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"assJoin", "/@", 
      RowBox[{"(", 
       RowBox[{"Normal", "@", 
        RowBox[{"Keys", "@", "ceItem"}]}], ")"}]}], "//", "Association"}], "//",
