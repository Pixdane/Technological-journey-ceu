Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"replaceItem", "[", "str_", "]"}], ":=", 
   RowBox[{
    RowBox[{"StringReplace", "[", 
     RowBox[{
      RowBox[{"\"\<icon: \\\"\>\"", "~~", 
       RowBox[{"x", ":", 
        RowBox[{
         RowBox[{"Except", "[", "\"\<\\\"\>\"", "]"}], ".."}]}], "~~", 
       "\"\<\\\"\>\""}], ":>", 
      RowBox[{"\"\<icon: \\\"\>\"", "<>", 
       RowBox[{"itemQuery", "@", "x"}], "<>", "\"\<\\\"\>\""}]}], "]"}], "@", 
    
    RowBox[{
     RowBox[{"StringReplace", "[", 
      RowBox[{
       RowBox[{"\"\<item: \\\"\>\"", "~~", 
        RowBox[{"x", ":", 
         RowBox[{
          RowBox[{"Except", "[", "\"\<\\\"\>\"", "]"}], ".."}]}], "~~", 
        "\"\<\\\"\>\""}], ":>", 
       RowBox[{"\"\<item: \\\"\>\"", "<>", 
        RowBox[{"itemQuery", "@", "x"}], "<>", "\"\<\\\"\>\""}]}], "]"}], "@",
      "str"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.952253983346992*^9, 3.952254010563155*^9}, {
