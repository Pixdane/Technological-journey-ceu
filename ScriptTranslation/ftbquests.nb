Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"assJoin", "[", "key_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ceValue", ",", "ceuValue"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ceValue", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Normal", "@", "ceItem"}], ")"}], "[", "key", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ceuValue", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Normal", "@", "ceuItem"}], ")"}], "[", "key", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Head", "@", "ceuValue"}], "=!=", "Missing"}], ",", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ceValue", "[", "\"\<Meta/dmg\>\"", "]"}], "==", "0"}], 
          ",", 
          RowBox[{
           RowBox[{"ceValue", "[", "\"\<Registry name\>\"", "]"}], "->", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Name\>\"", "->", 
              RowBox[{
               RowBox[{"ceuValue", "[", "\"\<Registry name\>\"", "]"}], "<>", 
               "\"\< 1 \>\"", "<>", 
               RowBox[{"ToString", "@", 
                RowBox[{"ceuValue", "[", "\"\<Meta/dmg\>\"", "]"}]}]}]}], ",", 
             RowBox[{"\"\<Display name\>\"", "->", 
              RowBox[{"ceuValue", "[", "\"\<Display name\>\"", "]"}]}]}], 
            "|>"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"ceValue", "[", "\"\<Registry name\>\"", "]"}], "<>", 
            "\"\< 1 \>\"", "<>", 
            RowBox[{"ToString", "@", 
             RowBox[{"ceValue", "[", "\"\<Meta/dmg\>\"", "]"}]}]}], "->", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Name\>\"", "->", 
              RowBox[{
               RowBox[{"ceuValue", "[", "\"\<Registry name\>\"", "]"}], "<>", 
               "\"\< 1 \>\"", "<>", 
               RowBox[{"ToString", "@", 
                RowBox[{"ceuValue", "[", "\"\<Meta/dmg\>\"", "]"}]}]}]}], ",", 
             RowBox[{"\"\<Display name\>\"", "->", 
              RowBox[{"ceuValue", "[", "\"\<Display name\>\"", "]"}]}]}], 
            "|>"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ceValue", "[", "\"\<Registry name\>\"", "]"}], "<>", 
          "\"\< 1 \>\"", "<>", 
          RowBox[{"ToString", "@", 
           RowBox[{"ceValue", "[", "\"\<Meta/dmg\>\"", "]"}]}]}], "->", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Name\>\"", "->", 
            RowBox[{"Missing", "[", "]"}]}], ",", 
           RowBox[{"\"\<Display name\>\"", "->", 
            RowBox[{"Missing", "[", "]"}]}]}], "|>"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
