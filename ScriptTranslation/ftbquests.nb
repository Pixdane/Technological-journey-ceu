Cell[BoxData[
 RowBox[{
  RowBox[{"itemQuery", "[", "item_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "res", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"res", "=", 
      RowBox[{"dictQ", "[", "item", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Head", "@", "res"}], "=!=", "Missing"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Head", "@", 
            RowBox[{"res", "[", "\"\<Name\>\"", "]"}]}], "=!=", "Missing"}], "&&", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Name\>\"", "]"}], "!=", "\"\<\>\""}]}], 
         ",", 
         RowBox[{"res", "[", "\"\<Name\>\"", "]"}], ",", "item"}], "]"}], ",",
        "\[IndentingNewLine]", "item"}], "\[IndentingNewLine]", "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
